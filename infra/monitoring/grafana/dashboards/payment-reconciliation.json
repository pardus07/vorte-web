{
  "dashboard": {
    "title": "Payment Reconciliation",
    "tags": ["payment", "reconciliation", "iyzico", "paytr"],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "30s",
    "time": {
      "from": "now-6h",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "title": "Reconciliation Overview",
        "type": "row",
        "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0}
      },
      {
        "id": 2,
        "title": "Stuck Payments (Requires Investigation)",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 0, "y": 1},
        "targets": [
          {
            "expr": "sum(reconciliation_stuck_total) by (provider)",
            "legendFormat": "{{provider}}"
          }
        ],
        "options": {
          "colorMode": "background",
          "graphMode": "none",
          "textMode": "value_and_name"
        },
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 1, "color": "yellow"},
                {"value": 5, "color": "red"}
              ]
            },
            "unit": "short"
          }
        }
      },
      {
        "id": 3,
        "title": "Reconciliation Call Rate",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 6, "y": 1},
        "targets": [
          {
            "expr": "sum(rate(reconciliation_calls_total[5m]))",
            "legendFormat": "Total"
          }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "area",
          "textMode": "value_and_name"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "reqps",
            "decimals": 2
          }
        }
      },
      {
        "id": 4,
        "title": "Recovery Success Rate",
        "type": "gauge",
        "gridPos": {"h": 4, "w": 6, "x": 12, "y": 1},
        "targets": [
          {
            "expr": "sum(rate(payment_webhook_total{result=~\"reconciliation_recovered_.*\"}[5m])) / sum(rate(reconciliation_calls_total[5m]))",
            "legendFormat": "Success Rate"
          }
        ],
        "options": {
          "showThresholdLabels": false,
          "showThresholdMarkers": true
        },
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "red"},
                {"value": 0.5, "color": "yellow"},
                {"value": 0.8, "color": "green"}
              ]
            },
            "unit": "percentunit",
            "min": 0,
            "max": 1
          }
        }
      },
      {
        "id": 5,
        "title": "Reconciliation Failure Rate",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 18, "y": 1},
        "targets": [
          {
            "expr": "sum(rate(payment_webhook_total{result=\"recon_fail\"}[5m])) / sum(rate(reconciliation_calls_total[5m]))",
            "legendFormat": "Failure Rate"
          }
        ],
        "options": {
          "colorMode": "background",
          "graphMode": "area",
          "textMode": "value"
        },
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 0.02, "color": "yellow"},
                {"value": 0.05, "color": "red"}
              ]
            },
            "unit": "percentunit",
            "decimals": 2
          }
        }
      },
      {
        "id": 6,
        "title": "Reconciliation Metrics by Provider",
        "type": "row",
        "gridPos": {"h": 1, "w": 24, "x": 0, "y": 5}
      },
      {
        "id": 7,
        "title": "Reconciliation Call Rate by Provider",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 6},
        "targets": [
          {
            "expr": "sum(rate(reconciliation_calls_total[5m])) by (provider)",
            "legendFormat": "{{provider}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "smooth",
              "fillOpacity": 10
            },
            "unit": "reqps"
          }
        }
      },
      {
        "id": 8,
        "title": "Payments Recovered by Provider",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 6},
        "targets": [
          {
            "expr": "sum(rate(payment_webhook_total{result=~\"reconciliation_recovered_.*\"}[5m])) by (provider)",
            "legendFormat": "{{provider}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {
              "drawStyle": "bars",
              "fillOpacity": 80
            },
            "unit": "reqps",
            "color": {"mode": "palette-classic"}
          }
        }
      },
      {
        "id": 9,
        "title": "API Latency",
        "type": "row",
        "gridPos": {"h": 1, "w": 24, "x": 0, "y": 14}
      },
      {
        "id": 10,
        "title": "Reconciliation API Latency (p50, p95, p99)",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 15},
        "targets": [
          {
            "expr": "histogram_quantile(0.50, sum(rate(reconciliation_call_latency_seconds_bucket[5m])) by (le, provider))",
            "legendFormat": "{{provider}} p50"
          },
          {
            "expr": "histogram_quantile(0.95, sum(rate(reconciliation_call_latency_seconds_bucket[5m])) by (le, provider))",
            "legendFormat": "{{provider}} p95"
          },
          {
            "expr": "histogram_quantile(0.99, sum(rate(reconciliation_call_latency_seconds_bucket[5m])) by (le, provider))",
            "legendFormat": "{{provider}} p99"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "smooth",
              "fillOpacity": 0
            },
            "unit": "s"
          }
        }
      },
      {
        "id": 11,
        "title": "Reconciliation API Latency Heatmap",
        "type": "heatmap",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 15},
        "targets": [
          {
            "expr": "sum(rate(reconciliation_call_latency_seconds_bucket[5m])) by (le)",
            "format": "heatmap",
            "legendFormat": "{{le}}"
          }
        ],
        "options": {
          "calculate": false,
          "cellGap": 2,
          "color": {
            "mode": "scheme",
            "scheme": "Spectral"
          }
        }
      },
      {
        "id": 12,
        "title": "Status Breakdown",
        "type": "row",
        "gridPos": {"h": 1, "w": 24, "x": 0, "y": 23}
      },
      {
        "id": 13,
        "title": "Recovered Payment Status Distribution",
        "type": "piechart",
        "gridPos": {"h": 8, "w": 8, "x": 0, "y": 24},
        "targets": [
          {
            "expr": "sum(increase(payment_webhook_total{result=~\"reconciliation_recovered_.*\"}[1h])) by (result)",
            "legendFormat": "{{result}}"
          }
        ],
        "options": {
          "legend": {
            "displayMode": "table",
            "placement": "right",
            "values": ["value", "percent"]
          },
          "pieType": "donut"
        }
      },
      {
        "id": 14,
        "title": "Reconciliation Results by Provider",
        "type": "bargauge",
        "gridPos": {"h": 8, "w": 8, "x": 8, "y": 24},
        "targets": [
          {
            "expr": "sum(increase(payment_webhook_total{result=~\"recon_.*\"}[1h])) by (provider, result)",
            "legendFormat": "{{provider}} - {{result}}"
          }
        ],
        "options": {
          "orientation": "horizontal",
          "displayMode": "gradient",
          "showUnfilled": true
        },
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 10, "color": "yellow"},
                {"value": 50, "color": "red"}
              ]
            }
          }
        }
      },
      {
        "id": 15,
        "title": "Stuck Payments Timeline",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 8, "x": 16, "y": 24},
        "targets": [
          {
            "expr": "sum(reconciliation_stuck_total) by (provider)",
            "legendFormat": "{{provider}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "stepAfter",
              "fillOpacity": 20
            },
            "unit": "short",
            "color": {"mode": "palette-classic"}
          }
        },
        "options": {
          "tooltip": {
            "mode": "multi"
          }
        }
      },
      {
        "id": 16,
        "title": "Error Analysis",
        "type": "row",
        "gridPos": {"h": 1, "w": 24, "x": 0, "y": 32}
      },
      {
        "id": 17,
        "title": "Reconciliation Errors Over Time",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 33},
        "targets": [
          {
            "expr": "sum(rate(payment_webhook_total{result=\"recon_fail\"}[5m])) by (provider)",
            "legendFormat": "{{provider}} failures"
          },
          {
            "expr": "sum(rate(payment_webhook_total{result=\"recon_transition_fail\"}[5m])) by (provider)",
            "legendFormat": "{{provider}} transition failures"
          },
          {
            "expr": "sum(rate(payment_webhook_total{result=\"recon_no_change\"}[5m])) by (provider)",
            "legendFormat": "{{provider}} no change"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "smooth",
              "fillOpacity": 10
            },
            "unit": "reqps"
          }
        }
      },
      {
        "id": 18,
        "title": "Error Rate by Type",
        "type": "table",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 33},
        "targets": [
          {
            "expr": "sum(increase(payment_webhook_total{result=~\"recon_.*\"}[1h])) by (provider, result)",
            "format": "table",
            "instant": true
          }
        ],
        "transformations": [
          {
            "id": "organize",
            "options": {
              "excludeByName": {"Time": true},
              "indexByName": {"provider": 0, "result": 1, "Value": 2},
              "renameByName": {
                "provider": "Provider",
                "result": "Result Type",
                "Value": "Count (1h)"
              }
            }
          }
        ],
        "options": {
          "showHeader": true,
          "sortBy": [{"displayName": "Count (1h)", "desc": true}]
        }
      }
    ],
    "templating": {
      "list": [
        {
          "name": "provider",
          "type": "query",
          "query": "label_values(reconciliation_calls_total, provider)",
          "multi": true,
          "includeAll": true,
          "allValue": ".*"
        }
      ]
    },
    "annotations": {
      "list": [
        {
          "name": "Deployments",
          "datasource": "Prometheus",
          "expr": "changes(up{job=\"vorte-api\"}[5m]) > 0",
          "tagKeys": "version",
          "textFormat": "Deployment",
          "iconColor": "blue"
        },
        {
          "name": "Alerts",
          "datasource": "Prometheus",
          "expr": "ALERTS{alertname=~\"Reconciliation.*\"}",
          "tagKeys": "alertname,severity",
          "textFormat": "{{alertname}}",
          "iconColor": "red"
        }
      ]
    }
  },
  "overwrite": true
}
