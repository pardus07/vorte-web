generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum UserRole {
  CUSTOMER
  ADMIN
}

enum DealerStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum Gender {
  ERKEK
  KADIN
}

enum Size {
  S
  M
  L
  XL
  XXL
}

enum OrderType {
  RETAIL
  WHOLESALE
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum InvoiceType {
  EFATURA
  EARSIV
}

enum InvoiceStatus {
  PENDING
  CREATED
  SENT
  ERROR
}

enum DiscountType {
  PERCENT
  FIXED
}

enum NotificationType {
  NEW_ORDER
  DEALER_ORDER
  PAYMENT_SUCCESS
  PAYMENT_FAILED
  STOCK_ALERT
  NEW_DEALER
}

// ==================== MODELS ====================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  phone         String?
  passwordHash  String
  role          UserRole  @default(CUSTOMER)
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  addresses  Address[]
  orders     Order[]
  favorites  Favorite[]
  cartItems  CartItem[]

  @@map("users")
}

model Dealer {
  id           String       @id @default(cuid())
  companyName  String
  taxNumber    String       @unique
  taxOffice    String
  dealerCode   String       @unique
  passwordHash String
  contactName  String
  phone        String
  email        String       @unique
  city         String
  district     String
  address      String
  status       DealerStatus @default(PENDING)
  approvedAt   DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  addresses    Address[]
  orders       Order[]
  dealerPrices DealerPrice[]
  cartItems    CartItem[]

  @@map("dealers")
}

model Address {
  id           String   @id @default(cuid())
  userId       String?
  dealerId     String?
  title        String
  fullName     String
  phone        String
  city         String
  district     String
  neighborhood String?
  address      String
  zipCode      String?
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  dealer Dealer? @relation(fields: [dealerId], references: [id], onDelete: Cascade)

  @@map("addresses")
}

model Category {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  image     String?
  gender    Gender
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]

  @@map("categories")
}

model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  categoryId  String
  gender      Gender
  basePrice   Float
  images      String[]
  active      Boolean  @default(true)
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category     Category      @relation(fields: [categoryId], references: [id])
  variants     Variant[]
  dealerPrices DealerPrice[]
  favorites    Favorite[]
  orderItems   OrderItem[]
  cartItems    CartItem[]

  @@map("products")
}

model Variant {
  id          String  @id @default(cuid())
  productId   String
  color       String
  colorHex    String
  size        Size
  sku         String  @unique
  gtinBarcode String? @unique
  stock       Int     @default(0)
  price       Float?
  active      Boolean @default(true)

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]
  cartItems  CartItem[]

  @@unique([productId, color, size])
  @@map("variants")
}

model DealerPrice {
  id             String  @id @default(cuid())
  productId      String
  dealerId       String?
  wholesalePrice Float
  minQuantity    Int     @default(1)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  dealer  Dealer? @relation(fields: [dealerId], references: [id], onDelete: Cascade)

  @@unique([productId, dealerId])
  @@map("dealer_prices")
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  userId          String?
  dealerId        String?
  type            OrderType
  status          OrderStatus @default(PENDING)
  totalAmount     Float
  shippingCost    Float       @default(0)
  discountAmount  Float       @default(0)
  addressSnapshot Json
  cargoTrackingNo String?
  cargoProvider   String?
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user     User?       @relation(fields: [userId], references: [id])
  dealer   Dealer?     @relation(fields: [dealerId], references: [id])
  items    OrderItem[]
  payment  Payment?
  invoice  Invoice?

  @@map("orders")
}

model OrderItem {
  id              String @id @default(cuid())
  orderId         String
  productId       String
  variantId       String
  quantity        Int
  unitPrice       Float
  totalPrice      Float
  productSnapshot Json

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
  variant Variant @relation(fields: [variantId], references: [id])

  @@map("order_items")
}

model Payment {
  id                    String        @id @default(cuid())
  orderId               String        @unique
  iyzicoPaymentId       String?
  iyzicoConversationId  String?
  status                PaymentStatus @default(PENDING)
  amount                Float
  paidAt                DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model Invoice {
  id           String        @id @default(cuid())
  orderId      String        @unique
  diaInvoiceId String?
  invoiceNo    String?
  invoiceType  InvoiceType?
  status       InvoiceStatus @default(PENDING)
  pdfUrl       String?
  sentAt       DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("invoices")
}

model Coupon {
  id            String       @id @default(cuid())
  code          String       @unique
  discountType  DiscountType
  discountValue Float
  minAmount     Float?
  maxUses       Int?
  currentUses   Int          @default(0)
  expiresAt     DateTime?
  active        Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@map("coupons")
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("favorites")
}

model CartItem {
  id        String   @id @default(cuid())
  sessionId String?
  userId    String?
  dealerId  String?
  productId String
  variantId String
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  dealer  Dealer? @relation(fields: [dealerId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant Variant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@map("cart_items")
}

model Notification {
  id        String           @id @default(cuid())
  type      NotificationType
  title     String
  message   String
  orderId   String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@map("notifications")
}
