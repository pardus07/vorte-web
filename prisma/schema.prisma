generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum UserRole {
  CUSTOMER
  ADMIN
  EDITOR
  VIEWER
}

enum DealerStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum Gender {
  ERKEK
  KADIN
}

enum Size {
  S
  M
  L
  XL
  XXL
}

enum OrderType {
  RETAIL
  WHOLESALE
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  PRODUCTION
  PRODUCTION_READY
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum InvoiceType {
  EFATURA
  EARSIV
}

enum InvoiceStatus {
  PENDING
  CREATED
  SENT
  ERROR
}

enum DiscountType {
  PERCENT
  FIXED
}

enum NotificationType {
  NEW_ORDER
  DEALER_ORDER
  PAYMENT_SUCCESS
  PAYMENT_FAILED
  PRODUCTION_TERMIN
  STOCK_ALERT
  NEW_DEALER
  VOICE_CALL
}

// ==================== MODELS ====================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  phone         String?
  passwordHash  String
  role          UserRole  @default(CUSTOMER)
  permissions   Json?     // Granüler yetkiler: { "products": "rw", "orders": "r", ... }
  emailVerified DateTime?
  image         String?
  active        Boolean   @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  addresses      Address[]
  orders         Order[]
  favorites      Favorite[]
  cartItems      CartItem[]
  activityLogs   ActivityLog[]
  reviews        ProductReview[]
  returnRequests ReturnRequest[]
  loyaltyPoints  LoyaltyPoint[]
  preferences    UserPreference?

  @@map("users")
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  action    String   // "login", "product.create", "order.update", etc.
  target    String?  // Target resource ID
  details   String?  // Additional context
  ip        String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("activity_logs")
}

model Dealer {
  id           String       @id @default(cuid())
  companyName  String
  taxNumber    String       @unique
  taxOffice    String
  dealerCode   String       @unique
  passwordHash String
  contactName  String
  phone        String
  email        String       @unique
  city         String
  district     String
  address      String

  // Fiziki Dükkan Bilgileri
  shopAddress  String?
  shopCity     String?
  shopDistrict String?

  // Ticari Koşullar
  discountRate     Float?          // Genel iskonto oranı %
  creditLimit      Float?          // Cari limit (₺)
  creditBalance    Float    @default(0) // Cari bakiye (₺, pozitif = borç)
  minOrderAmount   Float?          // Min sipariş tutarı (₺)
  minOrderQuantity Int?            // Min sipariş adedi
  paymentTermDays  Int      @default(0) // Vade günü (0 = peşin)

  // Bayi Seviye & Durum
  dealerTier   String       @default("standard") // standard, silver, gold, platinum
  status       DealerStatus @default(PENDING)
  approvedAt   DateTime?
  approvedBy   String?
  notes        String?      @db.Text

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  addresses      Address[]
  orders         Order[]
  dealerPrices   DealerPrice[]
  cartItems      CartItem[]
  dealerPayments DealerPayment[]

  @@map("dealers")
}

model Address {
  id           String   @id @default(cuid())
  userId       String?
  dealerId     String?
  title        String
  fullName     String
  phone        String
  city         String
  district     String
  neighborhood String?
  address      String
  zipCode      String?
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  dealer Dealer? @relation(fields: [dealerId], references: [id], onDelete: Cascade)

  @@map("addresses")
}

model Category {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  image     String?
  gender    Gender
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]

  @@map("categories")
}

model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  categoryId  String
  gender      Gender
  basePrice   Float
  costPrice   Float?
  weight      Float?
  images      String[]
  active      Boolean  @default(true)
  featured    Boolean  @default(false)

  // SEO
  seoTitle       String?
  seoDescription String?

  // Google Merchant
  googleCategory   String?
  merchantSynced   Boolean   @default(false)
  merchantSyncedAt DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category         Category          @relation(fields: [categoryId], references: [id])
  variants         Variant[]
  dealerPrices     DealerPrice[]
  favorites        Favorite[]
  orderItems       OrderItem[]
  cartItems        CartItem[]
  productCosts     ProductCost[]
  productionOrders ProductionOrder[]
  reviews          ProductReview[]

  @@map("products")
}

model Variant {
  id          String  @id @default(cuid())
  productId   String
  color       String
  colorHex    String
  size        Size
  sku         String  @unique
  gtinBarcode String? @unique
  stock       Int     @default(0)
  price       Float?
  active      Boolean @default(true)

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]
  cartItems  CartItem[]
  stockAlerts StockAlert[]

  @@unique([productId, color, size])
  @@map("variants")
}

model DealerPrice {
  id             String  @id @default(cuid())
  productId      String
  dealerId       String?
  wholesalePrice Float
  minQuantity    Int     @default(1)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  dealer  Dealer? @relation(fields: [dealerId], references: [id], onDelete: Cascade)

  @@unique([productId, dealerId])
  @@map("dealer_prices")
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  userId          String?
  dealerId        String?
  type            OrderType
  status          OrderStatus @default(PENDING)
  totalAmount     Float
  shippingCost    Float       @default(0)
  discountAmount  Float       @default(0)
  addressSnapshot Json
  cargoTrackingNo String?
  cargoProvider   String?
  cargoShipmentId  String?
  cargoTrackingUrl String?
  notes            String?
  adminNotes      String?     @db.Text
  couponCode      String?
  isProduction     Boolean    @default(false)  // Üretim siparişi mi?
  productionTermin DateTime?                   // Tahmini üretim teslim tarihi
  productionNote   String?                     // Admin üretim notu
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user            User?                @relation(fields: [userId], references: [id])
  dealer          Dealer?              @relation(fields: [dealerId], references: [id])
  items           OrderItem[]
  payment         Payment?
  invoice         Invoice?
  statusHistory   OrderStatusHistory[]
  returnRequests  ReturnRequest[]

  @@map("orders")
}

model OrderStatusHistory {
  id         String   @id @default(cuid())
  orderId    String
  fromStatus String?
  toStatus   String
  note       String?
  changedBy  String?
  createdAt  DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_status_history")
}

model OrderItem {
  id              String @id @default(cuid())
  orderId         String
  productId       String
  variantId       String
  quantity        Int
  unitPrice       Float
  totalPrice      Float
  productSnapshot Json

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
  variant Variant @relation(fields: [variantId], references: [id])

  @@map("order_items")
}

model Payment {
  id                    String        @id @default(cuid())
  orderId               String        @unique
  iyzicoPaymentId       String?
  iyzicoConversationId  String?
  status                PaymentStatus @default(PENDING)
  amount                Float
  paidAt                DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model Invoice {
  id           String        @id @default(cuid())
  orderId      String        @unique
  diaInvoiceId String?
  invoiceNo    String?
  invoiceSeries String       @default("VRT")
  invoiceType  InvoiceType?
  status       InvoiceStatus @default(PENDING)
  totalAmount  Float?
  taxAmount    Float?
  pdfUrl       String?
  issuedAt     DateTime?
  sentAt       DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("invoices")
}

model Coupon {
  id             String       @id @default(cuid())
  code           String       @unique
  name           String?
  discountType   DiscountType
  discountValue  Float
  minAmount      Float?
  maxUses        Int?
  maxUsesPerUser Int?
  currentUses    Int          @default(0)
  startsAt       DateTime?
  expiresAt      DateTime?
  active         Boolean      @default(true)

  // Kampanya türü & koşullar
  campaignType         String  @default("general")
  freeShipping         Boolean @default(false)
  buyQuantity          Int?
  getQuantity          Int?
  orderScope           String  @default("all")
  applicableProducts   String? @db.Text
  applicableCategories String? @db.Text
  description          String?

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@map("coupons")
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("favorites")
}

model CartItem {
  id               String   @id @default(cuid())
  sessionId        String?
  userId           String?
  dealerId         String?
  productId        String
  variantId        String
  quantity         Int      @default(1)
  standPackageId   String?  // Stand paketi instance ID — aynı ID = aynı paket
  standPackageType String?  // "A", "B" veya "C"
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user    User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  dealer  Dealer? @relation(fields: [dealerId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant Variant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@map("cart_items")
}

model Notification {
  id        String           @id @default(cuid())
  type      NotificationType
  title     String
  message   String
  orderId   String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@map("notifications")
}

model SiteSettings {
  id                    String   @id @default("main")

  // Genel
  siteName              String   @default("Vorte Tekstil")
  siteDescription       String?
  siteUrl               String   @default("https://www.vorte.com.tr")
  contactEmail          String?
  contactPhone          String?
  contactAddress        String?

  // Logo & Favicon
  logoUrl               String?
  logoDarkUrl           String?
  faviconUrl            String?
  ogImageUrl            String?

  // SEO
  metaTitle             String?
  metaDescription       String?
  metaKeywords          String?

  // Üçüncü Parti Kodlar
  googleVerificationCode String?
  googleAnalyticsId      String?
  googleAdsCode          String?  @db.Text
  googleMerchantId       String?
  facebookPixelId        String?

  // AI Chatbot
  aiSystemPrompt        String?  @db.Text
  aiEnabled             Boolean  @default(false)
  aiRules               String?  @db.Text
  aiModel               String   @default("claude-haiku-4-5-20251001")

  // Sosyal Medya
  instagramUrl          String?
  facebookUrl           String?
  twitterUrl            String?
  tiktokUrl             String?
  youtubeUrl            String?

  // E-posta Ayarları
  smtpHost              String?
  smtpPort              Int?
  smtpUser              String?
  smtpPassword          String?

  // Kargo Ayarları
  freeShippingThreshold Float?
  defaultShippingCost   Float?

  // Entegrasyon Ayarları
  iyzicoApiKey          String?
  iyzicoSecretKey       String?
  iyzicoSandboxMode     Boolean  @default(true)

  geliverApiKey         String?
  geliverApiBaseUrl     String?

  diaCrmUsername        String?
  diaCrmPassword        String?
  diaCrmCompanyCode     String?

  resendApiKey          String?
  resendFromEmail       String?  @default("noreply@vorte.com.tr")

  // Stand Paket Görselleri (JSON: { "A": "/uploads/stands/...", "B": "...", "C": "..." })
  standPackageImages    Json?

  updatedAt             DateTime @updatedAt

  @@map("site_settings")
}

model Slider {
  id            String    @id @default(cuid())
  title         String?
  subtitle      String?
  highlight     String?
  description   String?
  buttonText    String?
  buttonLink    String?
  secondaryButtonText String?
  secondaryButtonLink String?
  imageDesktop  String
  imageMobile   String
  altText       String?
  sortOrder     Int       @default(0)
  active        Boolean   @default(true)
  startDate     DateTime?
  endDate       DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("sliders")
}

model Banner {
  id            String    @id @default(cuid())
  name          String
  position      String    // "homepage-top", "homepage-mid", "product-sidebar", etc.
  imageDesktop  String
  imageMobile   String?
  link          String?
  altText       String?
  active        Boolean   @default(true)
  sortOrder     Int       @default(0)
  startDate     DateTime?
  endDate       DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("banners")
}

model DealerTierDiscount {
  id              String @id @default(cuid())
  tier            String @unique // standard, silver, gold, platinum
  discountRate    Float          // Genel iskonto oranı %
  minOrderAmount  Float  @default(0) // Min sipariş tutarı
  paymentTermDays Int    @default(0)
  description     String?

  @@map("dealer_tier_discounts")
}

model DealerPayment {
  id          String   @id @default(cuid())
  dealerId    String
  orderId     String?
  amount      Float
  type        String   // "payment" (ödeme), "debt" (borç/sipariş), "refund" (iade)
  method      String?  // "havale", "nakit", "cek", "kredi_karti"
  description String?
  createdAt   DateTime @default(now())

  dealer Dealer @relation(fields: [dealerId], references: [id], onDelete: Cascade)

  @@map("dealer_payments")
}

model ProductCost {
  id            String   @id @default(cuid())
  productId     String
  materialCost  Float    @default(0)
  laborCost     Float    @default(0)
  overheadCost  Float    @default(0)
  packagingCost Float    @default(0)
  totalCost     Float    @default(0)
  notes         String?
  calculatedAt  DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_costs")
}

model DailyReport {
  id           String   @id @default(cuid())
  date         DateTime @unique
  totalOrders  Int      @default(0)
  totalRevenue Float    @default(0)
  totalCost    Float    @default(0)
  totalProfit  Float    @default(0)
  orderBreakdown Json?
  createdAt    DateTime @default(now())

  @@map("daily_reports")
}

model EmailTemplate {
  id          String   @id @default(cuid())
  name        String   @unique // "order-confirmation", "shipping-notification" vb.
  subject     String
  body        String   @db.Text // HTML template
  variables   String?  // JSON: ["customerName", "orderNumber", ...]
  fromAddress String?  // Override FROM: "siparis@vorte.com.tr" vb.
  description String?  // Türkçe açıklama
  active      Boolean  @default(true)
  updatedAt   DateTime @updatedAt

  @@map("email_templates")
}

model EmailLog {
  id           String   @id @default(cuid())
  to           String
  subject      String
  templateId   String?
  templateName String?  // "order-confirmation" vb.
  fromAddress  String?  // Hangi FROM ile gönderildi
  status       String   // "sent", "failed", "bounced"
  error        String?
  provider     String?  // "smtp" | "resend" | "mock"
  body         String?  @db.Text
  sentAt       DateTime @default(now())

  @@map("email_logs")
}

model ContactMessage {
  id        String    @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String    @db.Text
  read      Boolean   @default(false)
  replied   Boolean   @default(false)
  replyText String?   @db.Text
  repliedAt DateTime?
  createdAt DateTime  @default(now())

  @@map("contact_messages")
}

// ============ ÜRETİM PLANLAMA ENUMLARİ ============

enum ProductionStage {
  PENDING           // Sipariş oluşturuldu, BOM bekleniyor
  BOM_CALCULATED    // BOM hesaplandı, tedarik bekleniyor
  MATERIALS_ORDERED // Tedarikçiye sipariş verildi
  MATERIALS_RECEIVED // Malzeme teslim alındı
  IN_PRODUCTION     // Fason atölyede üretimde
  QUALITY_CHECK     // Kalite kontrol aşamasında
  PACKAGING_STAGE   // Paketleniyor
  PROD_SHIPPED      // Kargoya verildi
  PROD_DELIVERED    // Teslim edildi
  PROD_CANCELLED    // İptal
}

enum SupplierType {
  FABRIC             // Penye Kumaş (Süprem, Ribana, İnterlok, Modal)
  THREAD             // İplik (Ring Combed, Compact, Penye İplik)
  ELASTIC_MALE       // Erkek Bel Lastiği (Jakarlı, Dokuma, Örme 30-40mm)
  ELASTIC_FEMALE     // Kadın Külot Lastiği (İnce elastik 8-12mm, Dantel, Biye)
  LABEL              // Dokuma Etiket (Marka, Beden, Yıkama talimatı, Barkod)
  FLEXIBLE_PACKAGING // Esnek Ambalaj (Şase lamine poşet, OPP, Zipli, Dijital baskı)
  CARDBOARD_PACKAGING // Karton Ambalaj (Kutu, Kartela, Askılı etiket, Sleeve)
  CARDBOARD_STAND    // Karton Stand (Tezgah üstü, Ada tipi, Tam boy)
  SEWING_THREAD      // Dikiş İpliği (Overlok, Reçme, Düz dikiş)
  ACCESSORY          // Aksesuar (Askı, Çengelli iğne, Silika jel, Bant)
  // Eski değerler (geriye uyumluluk)
  ELASTIC            // Eski: Genel lastik
  PACKAGING_MAT      // Eski: Genel ambalaj
}

enum QualityResult {
  PASSED
  FAILED
  CONDITIONAL  // Şartlı kabul
}

// ============ MEVCUT ÜRETİM EMRİ (Basit — Kanban) ============

model ProductionOrder {
  id              String    @id @default(cuid())
  orderNumber     String    @unique // ÜRT-2026-001
  productId       String
  product         Product   @relation(fields: [productId], references: [id])
  variants        Json      // [{ color: "Siyah", size: "M", quantity: 100 }, ...]
  totalQuantity   Int
  status          String    @default("planned") // planned, cutting, sewing, quality, packaging, completed
  priority        String    @default("normal") // low, normal, high, urgent
  startDate       DateTime?
  targetDate      DateTime
  completedDate   DateTime?
  materialCost    Float?
  laborCost       Float?
  notes           String?   @db.Text
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // İlişki: Tam üretim siparişine bağlantı (opsiyonel)
  fullProductionOrderId String?
  fullProductionOrder   FullProductionOrder? @relation(fields: [fullProductionOrderId], references: [id])

  logs ProductionLog[]

  @@map("production_orders")
}

model ProductionLog {
  id                String          @id @default(cuid())
  productionOrderId String
  productionOrder   ProductionOrder @relation(fields: [productionOrderId], references: [id], onDelete: Cascade)
  fromStatus        String
  toStatus          String
  note              String?
  changedBy         String?
  createdAt         DateTime        @default(now())

  @@map("production_logs")
}

// ============ TAM OTONOM ÜRETİM PLANLAMA SİSTEMİ ============

model FullProductionOrder {
  id              String   @id @default(cuid())
  orderNumber     String   @unique // "PO-2026-001" formatı

  // Bayi siparişinden geldiyse
  dealerOrderId   String?
  dealerId        String?

  // Sipariş detayları
  items           FullProductionOrderItem[]

  // Durum
  stage           ProductionStage @default(PENDING)
  stageHistory    Json     @default("[]") // [{stage, date, note, changedBy}]

  // BOM
  bomCalculation  BOMCalculation?

  // Termin
  estimatedDelivery DateTime?
  actualDelivery    DateTime?

  // Takip
  tracking        ProductionTracking[]
  qualityChecks   QualityCheck[]
  supplierOrders  SupplierOrder[]
  simpleOrders    ProductionOrder[]

  // Hedef tarih & toplam adet
  targetDate      DateTime?
  totalQuantity   Int      @default(0)

  // Notlar & meta
  notes           String?  @db.Text
  priority        String   @default("normal") // low, normal, high, urgent

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("full_production_orders")
}

model FullProductionOrderItem {
  id                String   @id @default(cuid())
  productionOrderId String
  productionOrder   FullProductionOrder @relation(fields: [productionOrderId], references: [id], onDelete: Cascade)

  productId         String   // Mevcut Product modeline referans
  sku               String   // "EB-S", "KK-T" vb.
  productName       String   // "Erkek Boxer Siyah"
  color             String

  // Beden bazlı adetler
  sizeS             Int      @default(0)
  sizeM             Int      @default(0)
  sizeL             Int      @default(0)
  sizeXL            Int      @default(0)
  sizeXXL           Int      @default(0)
  totalQuantity     Int      // Toplam adet

  createdAt         DateTime @default(now())

  @@map("full_production_order_items")
}

model BOMCalculation {
  id                String   @id @default(cuid())
  productionOrderId String   @unique
  productionOrder   FullProductionOrder @relation(fields: [productionOrderId], references: [id], onDelete: Cascade)

  // Hesaplanmış malzeme ihtiyaçları (JSON)
  materials         Json     // [{name, type, quantity, unit, perPiece, totalWeight}]

  // Özet
  totalFabricKg     Float    // Toplam ana kumaş (kg)
  totalLiningKg     Float    // Toplam iç katman (kg)
  totalElasticM     Float    // Toplam lastik (metre)
  totalThreadM      Float    // Toplam iplik (metre)
  totalLabels       Int      // Toplam etiket
  totalPackaging    Int      // Toplam ambalaj

  // Toplam ağırlık
  totalWeightKg     Float?

  // Maliyet
  estimatedCost     Float?

  calculatedAt      DateTime @default(now())

  @@map("bom_calculations")
}

model Supplier {
  id          String       @id @default(cuid())
  name        String
  email       String
  phone       String?
  type        SupplierType
  address     String?
  contactName String?

  // Tedarik bilgileri
  materials   Json?        // ["Ana Kumaş", "İç Katman"] gibi
  leadTimeDays Int?        // Ortalama teslim süresi (gün)
  minOrderQty String?      // "500 kg", "1000 m" gibi
  notes       String?      // Ürünler, kapasite, website gibi detay notları

  orders      SupplierOrder[]
  stocks      MaterialStock[]
  quotes      SupplierQuote[]

  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("suppliers")
}

model MaterialStock {
  id          String   @id @default(cuid())
  supplierId  String?
  supplier    Supplier? @relation(fields: [supplierId], references: [id])

  name        String   // "Ana Kumaş Penye+Elastan", "Bel Lastiği 4cm" vb.
  type        SupplierType
  quantity    Float    // Mevcut miktar
  unit        String   // "kg", "m", "adet"
  minQuantity Float    // Minimum stok seviyesi (altına düşünce alarm)

  lastRestocked DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("material_stocks")
}

model SupplierOrder {
  id                String   @id @default(cuid())
  supplierId        String
  supplier          Supplier @relation(fields: [supplierId], references: [id])
  productionOrderId String?
  productionOrder   FullProductionOrder? @relation(fields: [productionOrderId], references: [id])

  // Sipariş detayları
  materials         Json     // [{name, quantity, unit}]
  totalAmount       String?  // "50 kg Ana Kumaş + 200m Lastik" özet

  // Durum
  sentAt            DateTime?
  confirmedAt       DateTime?
  expectedDelivery  DateTime?
  deliveredAt       DateTime?

  // İletişim
  emailSent         Boolean  @default(false)
  emailContent      String?  @db.Text

  notes             String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("supplier_orders")
}

model ProductionTracking {
  id                String   @id @default(cuid())
  productionOrderId String
  productionOrder   FullProductionOrder @relation(fields: [productionOrderId], references: [id], onDelete: Cascade)

  stage             ProductionStage
  progress          Int      @default(0)  // 0-100 yüzde
  notes             String?

  createdAt         DateTime @default(now())

  @@map("production_tracking")
}

model QualityCheck {
  id                String   @id @default(cuid())
  productionOrderId String
  productionOrder   FullProductionOrder @relation(fields: [productionOrderId], references: [id], onDelete: Cascade)

  result            QualityResult
  inspectedQuantity Int      // Kontrol edilen adet
  defectQuantity    Int      @default(0) // Hatalı adet
  defectRate        Float?   // Hata oranı %

  passedQuantity    Int?     // Geçen adet (inspected - defect)

  // Detaylar
  defectDetails     Json?    // [{type: "dikiş hatası", count: 3}]
  photos            Json?    // ["url1", "url2"]

  inspectorNotes    String?

  createdAt         DateTime @default(now())

  @@map("quality_checks")
}

model Page {
  id             String   @id @default(cuid())
  title          String
  slug           String   @unique
  content        String   @db.Text
  seoTitle       String?
  seoDescription String?
  template       String   @default("default") // default, fullwidth, sidebar
  published      Boolean  @default(false)
  order          Int      @default(0)
  showInMenu     Boolean  @default(false)
  showInFooter   Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("pages")
}

model BlogPost {
  id             String    @id @default(cuid())
  title          String
  slug           String    @unique
  excerpt        String?
  content        String    @db.Text
  coverImage     String?
  seoTitle       String?
  seoDescription String?
  published      Boolean   @default(false)
  publishedAt    DateTime?
  authorName     String    @default("Vorte Tekstil")
  tags           String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@map("blog_posts")
}

model Redirect {
  id        String   @id @default(cuid())
  fromPath  String   @unique
  toPath    String
  permanent Boolean  @default(true)
  hits      Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("redirects")
}

model NotFoundLog {
  id        String   @id @default(cuid())
  path      String   @unique
  referer   String?
  userAgent String?
  hits      Int      @default(1)
  lastHitAt DateTime @default(now())
  createdAt DateTime @default(now())

  @@map("not_found_logs")
}

model ChatSession {
  id           String        @id @default(cuid())
  sessionToken String        @unique
  customerName String?
  customerEmail String?
  status       String        @default("active") // active, closed, admin_takeover
  aiEnabled    Boolean       @default(true)
  messageCount Int           @default(0)
  lastMessageAt DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  messages ChatMessage[]

  @@map("chat_sessions")
}

model ChatMessage {
  id          String      @id @default(cuid())
  sessionId   String
  session     ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role        String      // "user", "assistant", "admin"
  content     String      @db.Text
  createdAt   DateTime    @default(now())

  @@map("chat_messages")
}

model ProductReview {
  id        String   @id @default(cuid())
  userId    String
  productId String
  orderId   String?
  rating    Int      // 1-5
  title     String?
  comment   String?  @db.Text
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId, orderId])
  @@map("product_reviews")
}

model ReturnRequest {
  id              String   @id @default(cuid())
  userId          String
  orderId         String
  orderItemId     String?
  reason          String   // "beden_uyumsuz", "kusurlu", "yanlis_urun", "diger"
  description     String?  @db.Text
  status          String   @default("pending") // pending, approved, rejected, shipped, completed, refunded
  refundAmount    Float?
  cargoTrackingNo String?
  adminNote       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("return_requests")
}

model CallLog {
  id              String    @id @default(cuid())
  callId          String    @unique
  callerNumber    String
  callDirection   String    @default("inbound")
  status          String    @default("completed")
  startedAt       DateTime
  endedAt         DateTime?
  durationSeconds Int       @default(0)
  topics          String[]
  summary         String?
  sentiment       String?
  transcript      Json?
  audioUrl        String?
  transferredTo   String?
  isRead          Boolean   @default(false)
  notes           String?
  emailSent       Boolean   @default(false)
  createdAt       DateTime  @default(now())

  @@map("call_logs")
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("newsletter_subscribers")
}

model SupplierQuote {
  id              String   @id @default(cuid())
  supplierId      String
  supplier        Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  category        String   // FABRIC, THREAD, ELASTIC_MALE vs.
  productDetails  String   // Ne için teklif istendi
  quantity        String   // İstenen miktar
  unitPrice       Float?   // Birim fiyat (tedarikçi yanıtı)
  totalPrice      Float?   // Toplam fiyat
  currency        String   @default("TRY")
  minOrderQty     String?  // Minimum sipariş miktarı
  leadTimeDays    Int?     // Teslimat süresi (gün)
  validUntil      DateTime? // Teklifin geçerlilik tarihi
  notes           String?  // Tedarikçi notları
  status          String   @default("PENDING") // PENDING, SENT, RECEIVED, ACCEPTED, REJECTED
  emailSentAt     DateTime? // Mail gönderim zamanı
  receivedAt      DateTime? // Teklif alınma zamanı
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("supplier_quotes")
}

// ─── Kalıp ve Pastal Planlama ─────────────────────────────

model Pattern {
  id            String          @id @default(cuid())
  name          String          // "Erkek Boxer Brief M"
  modelType     String          // "boxer_brief", "trunk", "bikini", "hipster"
  gender        String          // "male", "female"
  baseSize      String          @default("M")
  parameters    Json            // tüm parametrik ölçüler
  pieces        Json            // parça geometrileri [{name, points, grainAngle, seamAllowances}]
  grading       Json?           // grade kuralları
  version       Int             @default(1)
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  nestingResults NestingResult[]
  @@map("patterns")
}

model NestingResult {
  id             String   @id @default(cuid())
  patternId      String
  pattern        Pattern  @relation(fields: [patternId], references: [id], onDelete: Cascade)
  orderId        String?
  fabricWidth    Float
  cuttingMethod  String   @default("straightKnife")
  sizeCombo      String
  placements     Json
  markerLength   Float
  efficiency     Float
  totalFabricM2  Float
  totalFabricKg  Float
  layCount       Int      @default(1)
  markerRepeats  Int      @default(1)
  createdAt      DateTime @default(now())

  @@map("nesting_results")
}

// ============ YENİ MODELLER (Eksik Özellikler) ============

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  title     String?         // "Bayi, Bursa" gibi
  avatar    String?
  rating    Int             // 1-5
  comment   String   @db.Text
  featured  Boolean  @default(false)
  approved  Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@map("testimonials")
}

model StockAlert {
  id        String   @id @default(cuid())
  email     String
  variantId String
  variant   Variant  @relation(fields: [variantId], references: [id], onDelete: Cascade)
  notified  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([email, variantId])
  @@map("stock_alerts")
}

model LoyaltyPoint {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  points      Int
  type        String    // "EARN", "SPEND", "EXPIRE"
  description String
  orderId     String?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@map("loyalty_points")
}

model GiftCard {
  id             String    @id @default(cuid())
  code           String    @unique
  initialAmount  Float
  balance        Float
  senderName     String?
  senderEmail    String?
  recipientName  String?
  recipientEmail String?
  message        String?
  active         Boolean   @default(true)
  expiresAt      DateTime?
  usedBy         String?
  createdAt      DateTime  @default(now())

  @@map("gift_cards")
}

model AbandonedCart {
  id           String    @id @default(cuid())
  userId       String?
  email        String?
  cartData     Json      // Sepet snapshot
  reminderSent Boolean   @default(false)
  recoveredAt  DateTime?
  createdAt    DateTime  @default(now())

  @@index([email])
  @@map("abandoned_carts")
}

model SearchLog {
  id        String   @id @default(cuid())
  query     String
  results   Int      @default(0)
  userId    String?
  createdAt DateTime @default(now())

  @@index([query])
  @@map("search_logs")
}

model UserPreference {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailOrders     Boolean  @default(true)
  emailPromotions Boolean  @default(true)
  emailStock      Boolean  @default(true)
  smsOrders       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("user_preferences")
}

// ============ MÜŞTERİ KEŞİF & TEKLİF SİSTEMİ ============

enum ProspectCategory {
  GAS_STATION    // Benzin istasyonu
  MARKET_CHAIN   // Market zinciri
  RETAIL_STORE   // Mağaza/Perakende
  HOTEL          // Otel
  CORPORATE      // Kurumsal
}

enum ProspectStatus {
  NEW            // Yeni keşfedildi
  CONTACTED      // Mail gönderildi
  OPENED         // Mail açıldı
  CLICKED        // Link tıklandı
  INTERESTED     // İlgilendi
  SAMPLE_SENT    // Numune gönderildi
  CONVERTED      // Bayi oldu
  REJECTED       // İlgilenmedi
}

model ProspectCustomer {
  id            String           @id @default(cuid())
  name          String
  category      ProspectCategory
  brand         String?          // Shell, BP, Opet vb.
  city          String
  district      String?
  address       String?
  phone         String?
  email         String?
  website       String?
  contactName   String?
  contactTitle  String?
  status        ProspectStatus   @default(NEW)
  notes         String?
  source        String?          // "gemini-discover"

  emails        OutreachEmail[]

  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([city])
  @@index([category])
  @@index([status])
  @@map("prospect_customers")
}

model OutreachEmail {
  id            String           @id @default(cuid())
  prospectId    String
  prospect      ProspectCustomer @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  subject       String
  body          String           @db.Text
  trackingId    String           @unique @default(cuid())
  sentAt        DateTime?
  openedAt      DateTime?
  openCount     Int              @default(0)
  clickedAt     DateTime?
  clickCount    Int              @default(0)
  status        String           @default("PENDING") // PENDING, SENT, FAILED
  createdAt     DateTime         @default(now())

  @@index([trackingId])
  @@map("outreach_emails")
}
