# Gemini AI
GEMINI_API_KEY=your-gemini-api-key

# LiveKit
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# Vorte API
VORTE_API_URL=https://www.vorte.com.tr
VORTE_API_KEY=your-server-api-key

# Netgsm SIP Trunk
NETGSM_SIP_HOST=sip.netgsm.com.tr
NETGSM_SIP_USERNAME=8503058635
NETGSM_SIP_PASSWORD=your-sip-password

# Netgsm (for SMS OTP in Phase 2)
NETGSM_USERCODE=
NETGSM_PASSWORD=
NETGSM_MSGHEADER=VORTE

# Agent Settings
AGENT_VOICE=Kore
SESSION_TIMEOUT_MINUTES=15
# TRANSFER_PHONE artık kullanılmıyor — FCM + LiveKit ile aktarma yapılıyor
