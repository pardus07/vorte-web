{# apps/backend/app/notifications/templates/en/emails/refund_issued.html.j2 #}
{% extends "en/base.html.j2" %}

{% set subject = "Refund Confirmed • " ~ refund.id %}
{% set preheader = "Your refund has been initiated." %}

{% block content %}
<h1>Refund Initiated 💰</h1>

<p>Hello {{ customer.first_name }},</p>

<p>
  Your refund of <strong>{{ refund.amount_formatted }}</strong> has been initiated.
  The refund amount will be reflected in your account within 5-10 business days.
</p>

<div class="divider"></div>

<h2 style="font-size: 18px; margin: 16px 0 8px;">Refund Details</h2>

<table role="presentation" cellpadding="0" cellspacing="0">
  <tbody>
    <tr>
      <td><strong>Refund ID:</strong></td>
      <td class="text-right">{{ refund.id }}</td>
    </tr>
    <tr>
      <td><strong>Payment ID:</strong></td>
      <td class="text-right">{{ payment.id }}</td>
    </tr>
    <tr>
      <td><strong>Order ID:</strong></td>
      <td class="text-right">{{ order.id }}</td>
    </tr>
    <tr>
      <td><strong>Refund Amount:</strong></td>
      <td class="text-right">{{ refund.amount_formatted }}</td>
    </tr>
    <tr>
      <td><strong>Original Amount:</strong></td>
      <td class="text-right">{{ payment.amount_formatted }}</td>
    </tr>
    <tr>
      <td><strong>Date:</strong></td>
      <td class="text-right">{{ refund.created_at }}</td>
    </tr>
    {% if refund.reason %}
    <tr>
      <td><strong>Reason:</strong></td>
      <td class="text-right">{{ refund.reason }}</td>
    </tr>
    {% endif %}
  </tbody>
</table>

<div style="background-color: #eff6ff; border-left: 4px solid #3b82f6; padding: 16px; margin: 24px 0; border-radius: 4px;">
  <p style="margin: 0; color: #1e40af;">
    <strong>Note:</strong> The refund will be credited to the card you used for payment.
    Depending on your bank, this process may take 5-10 business days.
  </p>
</div>

<p style="margin-top: 24px;">
  <a href="{{ order.tracking_url }}" class="btn">View Order</a>
</p>

<p class="muted" style="margin-top: 24px;">
  If you have any questions about your refund, please contact us with your refund ID ({{ refund.id }}).
</p>
{% endblock %}
