{# apps/backend/app/notifications/templates/en/emails/payment_authorized.html.j2 #}
{% extends "en/base.html.j2" %}

{% set subject = "Payment Confirmed • " ~ payment.id %}
{% set preheader = "Your payment has been successfully processed." %}

{% block content %}
<h1>Payment Successful ✓</h1>

<p>Hello {{ customer.first_name }},</p>

<p>
  Your payment of <strong>{{ payment.amount_formatted }}</strong> has been successfully processed.
</p>

<div class="divider"></div>

<h2 style="font-size: 18px; margin: 16px 0 8px;">Payment Details</h2>

<table role="presentation" cellpadding="0" cellspacing="0">
  <tbody>
    <tr>
      <td><strong>Payment ID:</strong></td>
      <td class="text-right">{{ payment.id }}</td>
    </tr>
    <tr>
      <td><strong>Order ID:</strong></td>
      <td class="text-right">{{ order.id }}</td>
    </tr>
    <tr>
      <td><strong>Amount:</strong></td>
      <td class="text-right">{{ payment.amount_formatted }}</td>
    </tr>
    <tr>
      <td><strong>Date:</strong></td>
      <td class="text-right">{{ payment.created_at }}</td>
    </tr>
    <tr>
      <td><strong>Payment Method:</strong></td>
      <td class="text-right">{{ payment.card_last4 }}</td>
    </tr>
  </tbody>
</table>

<p style="margin-top: 24px;">
  <a href="{{ order.tracking_url }}" class="btn">View Order</a>
</p>

<p class="muted" style="margin-top: 24px;">
  If you have any questions about this payment, please contact us with your payment ID ({{ payment.id }}).
</p>
{% endblock %}
