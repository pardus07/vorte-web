{# apps/backend/app/notifications/templates/en/emails/order_confirmation.html.j2 #}
{% extends "en/base.html.j2" %}

{% set subject = "Order Confirmation • " ~ order.id %}
{% set preheader = "Your order has been received. Details below." %}

{% block content %}
<h1>Order Received! 🎉</h1>

<p>Hello {{ customer.first_name }},</p>

<p>
  Your order (<strong>#{{ order.id }}</strong>) has been successfully received and is being processed.
  Your payment has been confirmed and we're preparing your order.
</p>

<div class="divider"></div>

<h2 style="font-size: 18px; margin: 16px 0 8px;">Order Details</h2>

<table role="presentation" cellpadding="0" cellspacing="0">
  <thead>
    <tr>
      <th>Product</th>
      <th class="text-right">Quantity</th>
      <th class="text-right">Price</th>
    </tr>
  </thead>
  <tbody>
    {% for item in order.order_items %}
    <tr>
      <td>{{ item.name }}</td>
      <td class="text-right">{{ item.quantity }}</td>
      <td class="text-right">{{ item.price_formatted }}</td>
    </tr>
    {% endfor %}
  </tbody>
  <tfoot>
    <tr style="border-top: 2px solid #111827;">
      <td colspan="2"><strong>Total</strong></td>
      <td class="text-right"><strong>{{ order.total_formatted }}</strong></td>
    </tr>
  </tfoot>
</table>

<div class="divider"></div>

<h2 style="font-size: 18px; margin: 16px 0 8px;">Delivery Information</h2>

<p class="muted">
  <strong>Address:</strong><br/>
  {{ customer.address.line1 }}<br/>
  {% if customer.address.line2 %}{{ customer.address.line2 }}<br/>{% endif %}
  {{ customer.address.city }}, {{ customer.address.postal_code }}<br/>
  {{ customer.address.country }}
</p>

<p style="margin-top: 24px;">
  <a href="{{ order.tracking_url }}" class="btn">View Order</a>
</p>

<p class="muted" style="margin-top: 24px;">
  If you have any questions about your order, please contact us with your order number (#{{ order.id }}).
</p>
{% endblock %}
