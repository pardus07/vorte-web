{# apps/backend/app/notifications/templates/tr/emails/payment_authorized.html.j2 #}
{% extends "tr/base.html.j2" %}

{% set subject = "Ödeme Onaylandı • " ~ payment.id %}
{% set preheader = "Ödemeniz başarıyla işlendi." %}

{% block content %}
<h1>Ödeme Başarılı ✓</h1>

<p>Merhaba {{ customer.first_name }},</p>

<p>
  <strong>{{ payment.amount_formatted }}</strong> tutarındaki ödemeniz başarıyla işlendi.
</p>

<div class="divider"></div>

<h2 style="font-size: 18px; margin: 16px 0 8px;">Ödeme Detayları</h2>

<table role="presentation" cellpadding="0" cellspacing="0">
  <tbody>
    <tr>
      <td><strong>Ödeme ID:</strong></td>
      <td class="text-right">{{ payment.id }}</td>
    </tr>
    <tr>
      <td><strong>Sipariş ID:</strong></td>
      <td class="text-right">{{ order.id }}</td>
    </tr>
    <tr>
      <td><strong>Tutar:</strong></td>
      <td class="text-right">{{ payment.amount_formatted }}</td>
    </tr>
    <tr>
      <td><strong>Tarih:</strong></td>
      <td class="text-right">{{ payment.created_at }}</td>
    </tr>
    <tr>
      <td><strong>Ödeme Yöntemi:</strong></td>
      <td class="text-right">{{ payment.card_last4 }}</td>
    </tr>
  </tbody>
</table>

<p style="margin-top: 24px;">
  <a href="{{ order.tracking_url }}" class="btn">Siparişi Görüntüle</a>
</p>

<p class="muted" style="margin-top: 24px;">
  Bu ödeme ile ilgili sorularınız için lütfen ödeme ID'nizi ({{ payment.id }}) belirterek bizimle iletişime geçin.
</p>
{% endblock %}
