{# apps/backend/app/notifications/templates/tr/emails/order_confirmation.html.j2 #}
{% extends "tr/base.html.j2" %}

{% set subject = "Sipariş Onayı • " ~ order.id %}
{% set preheader = "Siparişiniz alındı. Ayrıntılar aşağıda." %}

{% block content %}
<h1>Siparişiniz alındı! 🎉</h1>

<p>Merhaba {{ customer.first_name }},</p>

<p>
  Siparişiniz (<strong>#{{ order.id }}</strong>) başarıyla alındı ve işleme konuldu.
  Ödemeniz onaylandı ve siparişiniz hazırlanmaya başlandı.
</p>

<div class="divider"></div>

<h2 style="font-size: 18px; margin: 16px 0 8px;">Sipariş Detayları</h2>

<table role="presentation" cellpadding="0" cellspacing="0">
  <thead>
    <tr>
      <th>Ürün</th>
      <th class="text-right">Miktar</th>
      <th class="text-right">Fiyat</th>
    </tr>
  </thead>
  <tbody>
    {% for item in order.order_items %}
    <tr>
      <td>{{ item.name }}</td>
      <td class="text-right">{{ item.quantity }}</td>
      <td class="text-right">{{ item.price_formatted }}</td>
    </tr>
    {% endfor %}
  </tbody>
  <tfoot>
    <tr style="border-top: 2px solid #111827;">
      <td colspan="2"><strong>Toplam</strong></td>
      <td class="text-right"><strong>{{ order.total_formatted }}</strong></td>
    </tr>
  </tfoot>
</table>

<div class="divider"></div>

<h2 style="font-size: 18px; margin: 16px 0 8px;">Teslimat Bilgileri</h2>

<p class="muted">
  <strong>Adres:</strong><br/>
  {{ customer.address.line1 }}<br/>
  {% if customer.address.line2 %}{{ customer.address.line2 }}<br/>{% endif %}
  {{ customer.address.city }}, {{ customer.address.postal_code }}<br/>
  {{ customer.address.country }}
</p>

<p style="margin-top: 24px;">
  <a href="{{ order.tracking_url }}" class="btn">Siparişi Görüntüle</a>
</p>

<p class="muted" style="margin-top: 24px;">
  Siparişinizle ilgili sorularınız için lütfen sipariş numaranızı (#{{ order.id }}) belirterek bizimle iletişime geçin.
</p>
{% endblock %}
