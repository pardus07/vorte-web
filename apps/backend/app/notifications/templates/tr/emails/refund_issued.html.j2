{# apps/backend/app/notifications/templates/tr/emails/refund_issued.html.j2 #}
{% extends "tr/base.html.j2" %}

{% set subject = "İade Onayı • " ~ refund.id %}
{% set preheader = "İade işleminiz başlatıldı." %}

{% block content %}
<h1>İade İşlemi Başlatıldı 💰</h1>

<p>Merhaba {{ customer.first_name }},</p>

<p>
  <strong>{{ refund.amount_formatted }}</strong> tutarındaki iade işleminiz başlatıldı.
  İade tutarı 5-10 iş günü içinde hesabınıza yansıyacaktır.
</p>

<div class="divider"></div>

<h2 style="font-size: 18px; margin: 16px 0 8px;">İade Detayları</h2>

<table role="presentation" cellpadding="0" cellspacing="0">
  <tbody>
    <tr>
      <td><strong>İade ID:</strong></td>
      <td class="text-right">{{ refund.id }}</td>
    </tr>
    <tr>
      <td><strong>Ödeme ID:</strong></td>
      <td class="text-right">{{ payment.id }}</td>
    </tr>
    <tr>
      <td><strong>Sipariş ID:</strong></td>
      <td class="text-right">{{ order.id }}</td>
    </tr>
    <tr>
      <td><strong>İade Tutarı:</strong></td>
      <td class="text-right">{{ refund.amount_formatted }}</td>
    </tr>
    <tr>
      <td><strong>Orijinal Tutar:</strong></td>
      <td class="text-right">{{ payment.amount_formatted }}</td>
    </tr>
    <tr>
      <td><strong>Tarih:</strong></td>
      <td class="text-right">{{ refund.created_at }}</td>
    </tr>
    {% if refund.reason %}
    <tr>
      <td><strong>Sebep:</strong></td>
      <td class="text-right">{{ refund.reason }}</td>
    </tr>
    {% endif %}
  </tbody>
</table>

<div style="background-color: #eff6ff; border-left: 4px solid #3b82f6; padding: 16px; margin: 24px 0; border-radius: 4px;">
  <p style="margin: 0; color: #1e40af;">
    <strong>Not:</strong> İade tutarı, ödemeyi yaptığınız kartınıza geri yansıyacaktır.
    Bankanıza bağlı olarak bu işlem 5-10 iş günü sürebilir.
  </p>
</div>

<p style="margin-top: 24px;">
  <a href="{{ order.tracking_url }}" class="btn">Siparişi Görüntüle</a>
</p>

<p class="muted" style="margin-top: 24px;">
  İade işleminizle ilgili sorularınız için lütfen iade ID'nizi ({{ refund.id }}) belirterek bizimle iletişime geçin.
</p>
{% endblock %}
