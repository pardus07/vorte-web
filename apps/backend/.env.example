# Database
MONGO_URI=mongodb://mongo:27017/vorte
REDIS_URL=redis://redis:6379/0

# Security
JWT_SECRET=change_me_in_production_use_strong_random_key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# MinIO / S3
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=vorte-media
MINIO_SECURE=false

# Observability
PROMETHEUS_METRICS=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=vorte-api

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@vorte.com.tr
SMTP_PASSWORD=change_me
SMTP_FROM=noreply@vorte.com.tr

# Application
ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://localhost:80

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
